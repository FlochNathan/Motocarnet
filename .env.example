# Copiez ce fichier vers .env.local et remplissez les valeurs
# depuis votre projet Supabase : Settings > API
# ⚠️ Ne mettez JAMAIS de vraies clés dans ce fichier : il est versionné sur GitHub.
# Les vraies clés vont uniquement dans .env.local (ignoré par git).

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon

# Uniquement pour le script de seed démo (npm run seed:demo) — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=votre-cle-service-role
