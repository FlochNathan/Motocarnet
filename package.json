{
  "name": "moto-carnet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--use-system-ca next dev",
    "build": "next build",
    "start": "cross-env NODE_OPTIONS=--use-system-ca next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:demo": "node --use-system-ca scripts/seed-demo.mjs",
    "3d:export": "node scripts/export-motocross.mjs",
    "3d:optimize": "npx --yes @gltf-transform/cli optimize public/models/motocross.glb public/models/motocross.glb --texture-size 1024"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.48.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.171.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
